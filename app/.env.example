# MongoDB Atlas Configuration
# Each team member should use their own credentials

# Your MongoDB Atlas username (e.g., fa2927, jp8081, sl12190, wdc9645)
MONGO_USERNAME=your_username_here

# Your MongoDB Atlas password
MONGO_PASSWORD=your_password_here

# MongoDB cluster (usually same for all team members)
MONGO_CLUSTER=cluster0.jphivpd.mongodb.net

# Database name (same for all team members)
MONGO_DATABASE=big_data
