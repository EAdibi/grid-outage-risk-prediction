# MongoDB Atlas Configuration
# Copy this file to .env and replace with your actual credentials

# Example for Jithendra (jp8081)
MONGO_USERNAME=jp8081
MONGO_PASSWORD=your_actual_password_here
MONGO_CLUSTER=cluster0.jphivpd.mongodb.net
MONGO_DATABASE=big_data

